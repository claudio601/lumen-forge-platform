# === Pipedrive CRM Integration ===
# API credentials
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_BASE_URL=https://api.pipedrive.com/v1

# Quotes API
QUOTES_API_KEY=

# ── Pipeline de Cotizaciones (existente) ──────────────────────────────────────
PIPEDRIVE_PIPELINE_ID=
PIPEDRIVE_STAGE_NEW_LEAD_ID=

# Owner user (compartido entre pipelines)
PIPEDRIVE_OWNER_USER_ID=

# Activity type key (must match a valid type in your Pipedrive account)
# Common defaults: task, call, meeting, email, deadline
PIPEDRIVE_ACTIVITY_TYPE=task

# --- Deal custom fields (pipeline cotizaciones) ---
PIPEDRIVE_DEAL_FIELD_SOURCE_SYSTEM=
PIPEDRIVE_DEAL_FIELD_LEAD_TYPE=
PIPEDRIVE_DEAL_FIELD_PRIORITY_TIER=
PIPEDRIVE_DEAL_FIELD_FOLLOWUP_24=
PIPEDRIVE_DEAL_FIELD_FOLLOWUP_72=
PIPEDRIVE_DEAL_FIELD_QUOTE_REFERENCE=
PIPEDRIVE_FIELD_JUMPSELLER_ORDER_ID=
# Tipo: Enum (single option) | Field key compartido entre todos los pipelines.
# Opciones (option ID numerico): 89=Cotizacion Web, 90=Instalacion Profesional,
# 91=Estudio Luminico, 92=WhatsApp, 93=Jumpseller.
PIPEDRIVE_FIELD_TIPO_SERVICIO=

# --- Person custom fields ---
PIPEDRIVE_PERSON_FIELD_CUSTOMER_TYPE=
PIPEDRIVE_PERSON_FIELD_PREFERRED_CHANNEL=

# --- Organization custom fields ---
PIPEDRIVE_ORG_FIELD_SEGMENT=
PIPEDRIVE_ORG_FIELD_IS_B2B_PRIORITY=
PIPEDRIVE_ORG_FIELD_BILLING_COMMUNE=

# ── Pipeline de Instalacion Profesional (nuevo) ───────────────────────────────
# Pasos para obtener los IDs:
#   1. Crear pipeline en Pipedrive: Settings > Pipelines > Add Pipeline
#      Nombre sugerido: "Instalacion Profesional"
#      Stages: Nuevo lead | Precalificado | Visita agendada | Cotizacion enviada
#              | Aprobada | En ejecucion | Completado | Perdido
#   2. GET /v1/pipelines?api_token=TU_TOKEN  -> copiar id del nuevo pipeline
#   3. GET /v1/stages?pipeline_id=ID&api_token=TU_TOKEN -> copiar id del stage "Nuevo lead"
#   4. Crear custom fields en Settings > Data Fields > Deals
#      (ver comentarios en api/installation-leads/create.ts para tipos y nombres)
#   5. Copiar el field "key" de cada campo creado en las variables de abajo

PIPEDRIVE_INSTALL_PIPELINE_ID=
PIPEDRIVE_INSTALL_STAGE_NEW_LEAD_ID=

# --- Deal custom fields (pipeline instalacion) ---
# Tipo: Enum | Valores: instalacion_web, whatsapp_bot, manual
PIPEDRIVE_INSTALL_FIELD_SOURCE=
# Tipo: Enum | Valores: Casa / departamento, Oficina, Local comercial, Bodega,
#                        Condominio / edificio, Proyecto industrial, Paneles solares, Otro
PIPEDRIVE_INSTALL_FIELD_PROJECT_TYPE=
# Tipo: Enum | Valores: hogar, empresa, condominio
PIPEDRIVE_INSTALL_FIELD_CLIENT_TYPE=
# Tipo: Text
PIPEDRIVE_INSTALL_FIELD_COMMUNE=
# Tipo: Text (Large / Textarea)
PIPEDRIVE_INSTALL_FIELD_DESCRIPTION=
# Tipo: Boolean (Checkbox)
PIPEDRIVE_INSTALL_FIELD_NEEDS_VISIT=
# Tipo: Enum | Valores: whatsapp, llamada, email
PIPEDRIVE_INSTALL_FIELD_CONTACT_PREF=
# Tipo: Text | Uso: referencia interna INST-xxxxx (idempotencia)
PIPEDRIVE_INSTALL_FIELD_LEAD_REF=

# ── Webhook auth ──────────────────────────────────────────────────────────────
# Jumpseller: get Hooks Token from Admin > Config > Notifications/Webhooks
JUMPSELLER_HOOKS_TOKEN=
# Pipedrive: set these credentials when registering the webhook (http_auth_user / http_auth_password)
PIPEDRIVE_WEBHOOK_USER=
PIPEDRIVE_WEBHOOK_PASSWORD=

# ── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── Upstash Redis (distributed idempotency + lock) ─────────────────────────────
# Required for Jumpseller deduplication. If not set, creator events fail closed
# with 503 so Jumpseller retries.
# Get from: https://console.upstash.com -> Create Database -> REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Request Orders (Solicitud de Pedido) ────────────────────────────────────────
# Email de ventas para GAS relay (default: ventas@elights.cl)
SALES_EMAIL=ventas@elights.cl

# ── Pipeline Estudio Luminico DIALux (V1: comparte pipeline Ventas eLIGHTS) ──
# V1: usa PIPEDRIVE_PIPELINE_ID y PIPEDRIVE_STAGE_NEW_LEAD_ID existentes.
# El campo PIPEDRIVE_ESTUDIO_FIELD_SERVICE_TYPE distingue este flujo.
# TODO (V2): crear pipeline dedicado "Estudio Luminico" y agregar:
#   PIPEDRIVE_ESTUDIO_PIPELINE_ID=
#   PIPEDRIVE_ESTUDIO_STAGE_NEW_LEAD_ID=

# --- Deal custom fields (pipeline estudio luminico) ---
# Tipo: Enum | Valores: Estudio Luminico
# Crear en Pipedrive: Settings > Data Fields > Deals > Add Field
PIPEDRIVE_ESTUDIO_FIELD_SERVICE_TYPE=
# Tipo: Enum | Valores: estudio_luminico_web, manual
PIPEDRIVE_ESTUDIO_FIELD_SOURCE=
# Tipo: Enum | Valores: cancha_deportiva, industria_bodega, etc.
PIPEDRIVE_ESTUDIO_FIELD_PROJECT_TYPE=
# Tipo: Text
PIPEDRIVE_ESTUDIO_FIELD_COMMUNE=
# Tipo: Enum | Valores: si_dwg_listo, si_preparar, no_tengo
PIPEDRIVE_ESTUDIO_FIELD_HAS_PLANS=
# Tipo: Text
PIPEDRIVE_ESTUDIO_FIELD_DIMENSIONS=
# Tipo: Text
PIPEDRIVE_ESTUDIO_FIELD_MOUNT_HEIGHT=
# Tipo: Enum | Valores: entrenamiento, competencia, operacion_industrial, etc.
PIPEDRIVE_ESTUDIO_FIELD_OBJECTIVE=
# Tipo: Enum | Valores: criterios_fifa, en_12193, en_12464, en_13201, sec_chile, no_seguro
PIPEDRIVE_ESTUDIO_FIELD_NORM=
# Tipo: Enum | Valores: urgente, este_mes, evaluando, futura_licitacion
PIPEDRIVE_ESTUDIO_FIELD_URGENCY=
# Tipo: Text | Nombre de empresa
PIPEDRIVE_ESTUDIO_FIELD_COMPANY=
# Tipo: Text (Large) | Descripcion del proyecto
PIPEDRIVE_ESTUDIO_FIELD_DESCRIPTION=
# Tipo: Text | Uso: referencia interna ESTL-xxxxx (idempotencia/dedup)
PIPEDRIVE_ESTUDIO_FIELD_LEAD_REF=
# NOTA: Si ninguno de estos campos esta configurado, todos los datos del
# formulario se guardan en la nota estructurada del deal. El endpoint funciona
# sin estas variables — son optimizaciones de busqueda y filtrado en Pipedrive.
